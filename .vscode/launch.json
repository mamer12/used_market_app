{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Mustamal (DEV)",
            "request": "launch",
            "type": "dart",
            "program": "lib/main_dev.dart",
            "args": [
                "--flavor",
                "development",
                "--target",
                "lib/main_dev.dart"
            ],
            "flutterMode": "debug"
        },
        {
            // Use this config when running on a physical iPhone/Android.
            // Update DEV_HOST to your Mac's local IP (run: ifconfig | grep 192)
            "name": "Mustamal (DEV - Device)",
            "request": "launch",
            "type": "dart",
            "program": "lib/main_dev.dart",
            "args": [
                "--flavor",
                "development",
                "--target",
                "lib/main_dev.dart",
                "--dart-define=DEV_HOST=192.168.68.104"
            ],
            "flutterMode": "debug"
        },
        {
            "name": "Mustamal (PROD)",
            "request": "launch",
            "type": "dart",
            "program": "lib/main_prod.dart",
            "args": [
                "--flavor",
                "production",
                "--target",
                "lib/main_prod.dart"
            ],
            "flutterMode": "release"
        }
    ]
}