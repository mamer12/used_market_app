# Luqta Flutter App Environment Configuration
# Copy this file to .env and fill in the values

# Environment
ENV=dev

# API Configuration
API_BASE_URL=http://10.0.2.2:8080
API_VERSION=v1

# Web App Configuration (React Madhmoon)
WEB_URL=http://10.0.2.2:5173

# WebSocket Configuration
WS_URL=ws://10.0.2.2:8080

# CDN Configuration
CDN_URL=http://10.0.2.2:9000

# Cookie Configuration
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false

# Feature Flags
ENABLE_MAZADAT=true
ENABLE_MATAJIR=true
ENABLE_BALLA=true
ENABLE_MUSTAMAL=true
ENABLE_CHAT=false
ENABLE_ACTIVITY=true

# Optional: Override development host
DEV_WEB_HOST=

# Optional: Analytics and Monitoring
SENTRY_DSN=
FIREBASE_API_KEY=
GOOGLE_ANALYTICS_ID=

# Optional: Third-party Services
ONESIGNAL_APP_ID=
GOOGLE_MAPS_API_KEY=
